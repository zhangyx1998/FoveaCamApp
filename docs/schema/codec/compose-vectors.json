      -0.015,
      0.002,
      0.004,
      -0.025
     ],
     "feedForward": true
    },
    "expected": {
     "l": {
      "x": 1.0,
      "y": 2.0
     },
     "r": {
      "x": 3.0,
      "y": 4.0
     }
    }
   },
   {
    "op": "pred",
    "note": "prediction tick applies J1*(c1-p1)",
