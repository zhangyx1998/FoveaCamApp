{
  "compilerOptions": {
    "paths": {
      "@lib/*": [
        "./lib/*"
      ],
      "@src/*": [
        "./src/*"
      ],
      "@modules/*": [
        "./modules/*"
      ],
      "@orchestrator/*": [
        "./orchestrator/*"
      ],
    },
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": [
      "ESNext",
      "DOM"
    ],
    "skipLibCheck": true,
    "noEmit": true,
    "types": [
      "vite/client",
      "@zhangyx1998/svg-loader/client"
    ]
  },
  "include": [
    "src",
    "lib",
    "modules",
    "orchestrator",
    "scripts",
    "test/port-pipe.types.ts",
    "*.d.ts"
  ]
}
