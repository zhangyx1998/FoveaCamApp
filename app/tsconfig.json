{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@lib/*": ["lib/*"],
            "@src/*": ["src/*"],
            "@modules/*": ["modules/*"],
        },
        "target": "ESNext",
        "useDefineForClassFields": true,
        "module": "ESNext",
        "moduleResolution": "Node",
        "strict": true,
        "jsx": "preserve",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "lib": ["ESNext", "DOM"],
        "skipLibCheck": true,
        "noEmit": true
    },
    "include": ["src", "lib", "modules"],
    "references": [{ "path": "./tsconfig.node.json" }]
}
